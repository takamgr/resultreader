<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- 撮影画像表示エリア（画面の60%） -->
    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:background="#111111">

        <ImageView
            android:id="@+id/capturedImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

        <!-- ドラッグ可能な赤枠オーバーレイ（撮影後に表示） -->
        <com.example.resultreader.RoiOverlayView
            android:id="@+id/roiOverlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- 未撮影時のヒント表示 -->
        <LinearLayout
            android:id="@+id/hintLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="「テスト撮影」を押すと画像が表示されます"
                android:textColor="#888888"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- コントロールパネル（画面の40%） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:background="#1A1A1A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- テスト撮影ボタン -->
            <Button
                android:id="@+id/captureButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="テスト撮影"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"
                app:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

            <!-- 現在使用中の機種 -->
            <TextView
                android:id="@+id/activeDeviceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用中: (未設定)"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- 機種選択 + 削除 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="保存済み機種"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Spinner
                    android:id="@+id/deviceSpinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="#333333" />

                <Button
                    android:id="@+id/deleteDeviceButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="削除"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    app:backgroundTint="#E53935"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- 機種名入力 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="機種名（新規登録は新しい名前を入力）"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/deviceNameEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:background="#333333"
                android:padding="6dp"
                android:textSize="14sp"
                android:hint="例: Pixel 7"
                android:textColorHint="#666666"
                android:layout_marginBottom="10dp" />

            <!-- X / Y -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="X (left px)"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/roiEditX"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"
                        android:background="#333333"
                        android:padding="6dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Y (top px)"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/roiEditY"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"
                        android:background="#333333"
                        android:padding="6dp"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Width / Height -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Width (px)"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/roiEditWidth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#FFFFFF"
                        android:background="#333333"
                        android:padding="6dp"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Height (auto)"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/roiEditHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#888888"
                        android:background="#222222"
                        android:padding="6dp"
                        android:textSize="14sp"
                        android:enabled="false" />
                </LinearLayout>

            </LinearLayout>

            <!-- 回転角度 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="回転角度"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/roiBtn0"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="0°"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/roiBtn90"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="90°"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/roiBtn180"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="180°"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/roiBtn270"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="270°"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- 保存ボタン -->
            <Button
                android:id="@+id/roiSaveButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="保存して使用"
                android:textSize="16sp"
                app:backgroundTint="#2196F3"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
